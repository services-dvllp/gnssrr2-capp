	misc_clk_0 {
		#clock-cells = <0x00>;
		clock-div = <0x07>;
		clock-mult = <0x01>;
		clocks = <0x04 0x47>;
		compatible = "fixed-factor-clock";
		phandle = <0x1b>;
	};

	misc_clk_1 {
		#clock-cells = <0x00>;
		clock-div = <0x03>;
		clock-mult = <0x01>;
		clocks = <0x04 0x47>;
		compatible = "fixed-factor-clock";
		phandle = <0x1c>;
	};

	chosen {
		bootargs = "earlycon console=ttyPS0,115200 root=/dev/mmcblk1p2 ro rootwait rw";
		stdout-path = "serial0:115200n8";
	};

	aliases {
		ethernet0 = "/axi/ethernet@ff0e0000";
		i2c0 = "/axi/i2c@ff030000";
